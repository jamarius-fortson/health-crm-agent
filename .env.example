# =============================================================================
# Healthcare CRM Agent — Environment Configuration
# =============================================================================
# NEVER commit real credentials or PHI to version control.
# Copy this file to .env and fill in values for your deployment.
# All LLM endpoints MUST be BAA-covered — no exceptions.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://hcrm:hcrm_password@localhost:5432/hcrm_db
DATABASE_URL_AUDIT=postgresql+asyncpg://hcrm_audit:hcrm_audit_password@localhost:5432/hcrm_audit_db
REDIS_URL=redis://localhost:6379/0

# --- LLM (BAA-COVERED ONLY — pick primary + optional fallback) ---
# Primary: AWS Bedrock with Claude (requires BAA with AWS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_baa_covered_key
AWS_SECRET_ACCESS_KEY=your_baa_covered_secret
LLM_PRIMARY_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# Fallback: Azure OpenAI (requires BAA with Microsoft)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_baa_covered_key
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# LLM_FALLBACK_MODEL=azure-openai

# Self-hosted option for air-gapped clinics
# LLM_SELF_HOSTED_ENDPOINT=http://localhost:8000/v1
# LLM_SELF_HOSTED_MODEL=local-model

# --- LLM Cost Guard ---
LLM_DAILY_COST_CAP_USD=50.00
LLM_CHEAP_MODEL_FOR_OPERATIONAL=anthropic.claude-3-haiku-20240307-v1:0

# --- Encryption ---
ENCRYPTION_KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789012:key/your-key-id
ENCRYPTION_KEY_ID=hcrm-field-encryption-key

# --- Messaging (BAA-COVERED) ---
TWILIO_ACCOUNT_SID=your_baa_covered_sid
TWILIO_AUTH_TOKEN=your_baa_covered_token
TWILIO_PHONE_NUMBER=+15551234567

PAUBOX_API_KEY=your_baa_covered_key
PAUBOX_FROM_EMAIL=noreply@yourclinic.com

# --- Clearinghouse (for insurance eligibility) ---
CLEARINGHOUSE_PROVIDER=change_healthcare  # change_healthcare, availity, pverify
CHANGE_HEALTHCARE_API_URL=https://apis.changehealthcare.com
CHANGE_HEALTHCARE_CLIENT_ID=your_client_id
CHANGE_HEALTHCARE_CLIENT_SECRET=your_client_secret

# --- Authentication (OIDC + MFA) ---
OIDC_ISSUER_URL=https://your-oidc-provider.com/realms/hcrm
OIDC_CLIENT_ID=hcrm-client
OIDC_CLIENT_SECRET=your_oidc_secret
MFA_REQUIRED=true
SESSION_TIMEOUT_MINUTES=15

# --- Clinic Configuration ---
CLINIC_NAME=Example Primary Care Clinic
CLINIC_TIMEZONE=America/New_York
CLINIC_PHONE=+15551234567

# --- Audit ---
AUDIT_WORM_STORAGE_PATH=/var/lib/hcrm/audit

# --- Telemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090

# --- Breach Detection ---
SECURITY_OFFICER_EMAIL=security@yourclinic.com
ALERT_THRESHOLD_UNUSUAL_PHI_READS_PER_HOUR=100

# --- State Law Compliance ---
CLINIC_STATE=NY
RETENTION_YEARS=6
